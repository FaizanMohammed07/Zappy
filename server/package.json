{
  "name": "hyperlocal-server",
  "version": "3.0.0",
  "description": "Hyperlocal instant service platform - backend with monetization",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker:dispatch": "node src/jobs/dispatch.worker.js",
    "worker:notifications": "node src/jobs/notifications.worker.js",
    "worker:stale": "node src/jobs/stale-order.worker.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "bootstrap:admin": "node scripts/bootstrap-admin.js",
    "bootstrap:indexes": "node scripts/create-indexes.js",
    "bootstrap:monetization": "node scripts/bootstrap-monetization.js",
    "bootstrap:catalog": "node scripts/bootstrap-catalog.js",
    "seed": "node scripts/seed.js",
    "sweep:subs": "node scripts/expire-subscriptions.js",
    "sweep:subs:loop": "node scripts/expire-subscriptions.js --loop"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.670.0",
    "@aws-sdk/s3-request-presigner": "^3.670.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.21.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.3",
    "morgan": "^1.10.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.8.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEach": [
      "<rootDir>/tests/teardown.js"
    ],
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "testTimeout": 30000,
    "maxWorkers": 1
  }
}
