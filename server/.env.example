NODE_ENV=development
PORT=4000

MONGO_URI=mongodb+srv://aliffaizan1212_db_user:zappy@cluster0.5jall1k.mongodb.net/?appName=Cluster0
REDIS_URL=redis://localhost:6379

JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

GOOGLE_MAPS_KEY=your_google_maps_server_key

AWS_REGION=ap-south-1
AWS_S3_BUCKET=hyperlocal-uploads
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret

DISPATCH_RADIUS_KM=5
DISPATCH_MAX_CANDIDATES=20
DISPATCH_OFFER_TIMEOUT_MS=15000

BASE_FEE=40
PER_KM_FEE=12
PER_MIN_FEE=2
PLATFORM_FEE=10
MIN_FARE=60

# --- Razorpay ---
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Webhook secret — set this in Razorpay dashboard webhook config
# Subscribe to: payment.captured, order.paid, payment.failed, refund.processed
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
# For Razorpay Payouts (RX) — worker withdrawals
RAZORPAY_VIRTUAL_ACCOUNT=your_rx_virtual_account

# --- Calling (masked numbers) ---
# Provider is pluggable — in dev leave as 'mock'. Set to 'twilio' or 'exotel'
# and add the corresponding provider credentials before enabling masked calls.
CALL_PROVIDER=mock
# Comma-separated pool of rented virtual numbers. More numbers = more concurrent
# calls. Each number is reserved for ~2h past order completion.
CALL_POOL_NUMBERS=+911800123001,+911800123002,+911800123003,+911800123004
