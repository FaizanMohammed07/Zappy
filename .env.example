# Root .env — read by docker-compose to pass VITE_* build args to the client container.
# Copy this file to .env on your EC2 instance and fill in all values.

# Public domain — used by SEO schema generators and sitemap BASE_URL
PUBLIC_URL=https://www.yourdomain.com

# SECURITY: Never commit real values here — use placeholders only
VITE_ADMIN_SLUG=your-secret-admin-slug-here
VITE_CASHFREE_ENV=production
VITE_GOOGLE_MAPS_KEY=your_google_maps_key
VITE_MAPBOX_TOKEN=your_mapbox_token
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_VAPID_KEY=your_vapid_key
